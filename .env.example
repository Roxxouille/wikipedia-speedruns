# Copy to .env and change all secrets before deploying.
WEB_PORT=80

SECRET_KEY=change-me-to-a-long-random-value
DATABASE=wikipedia_speedruns
MYSQL_USER=wikispeedruns
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Mail/password reset/account confirmation. Leave blank to disable real mail delivery.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_USE_TLS=true
# Set true if you want registrations/password-reset emails to be skipped instead of sent.
# Useful when you do not have SMTP configured yet.
MAIL_SUPPRESS_SEND=false

# Google OAuth. Leave blank if you are not using Google login.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional monitoring.
SENTRY_ENABLED=false

# Optional prompt generator file. Example: mount ./data/pagerank.txt and set this path.
# PAGERANK_FILE=/data/pagerank.txt
